LOG_LEVEL=INFO

# Gemini
GOOGLE_API_KEY=your_google_api_key
# Optional alias. If GOOGLE_API_KEY is empty, the repo will fall back to GEMINI_API_KEY.
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
# Optional: pin Neo4j vector index dimension if you do not want schema creation
# to probe the embedding API automatically.
EMBEDDING_VECTOR_DIMENSIONS=

# Langfuse
LANGFUSE_TRACING_ENABLED=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_ENVIRONMENT=local
LANGFUSE_RELEASE=
LANGFUSE_TRACE_NAME=
OUTPUT_PATH=./output/langfuse_export.json
DATA_PATH=./eval/data

# DeepEval / KBV
CONFIDENT_API_KEY=

# Retrieval / ontology
RETRIEVAL_STRATEGY=heuristic
# heuristic | vector_rag | graph_rag | ontology_only | traversal_only | learned | full
ALLOW_DEFAULT_EXAMPLE_PADDING=false
ONTOLOGY_PROTOTYPES_PATH=./output/langfuse_export.ontology_prototypes.json
ONTOLOGY_SPLIT_MANIFEST_PATH=./output/langfuse_export.ontology_split_manifest.json
ONTOLOGY_TRAIN_SPLIT=train
ONTOLOGY_TOP_K=5
LEARNED_RETRIEVAL_TOP_K=6
TRAVERSAL_POLICY_PATH=./output/langfuse_export.traversal_policy.json
TRAVERSAL_SPLIT_MANIFEST_PATH=./output/langfuse_export.traversal_split_manifest.json
TRAVERSAL_TRAIN_SPLIT=train
TRAVERSAL_TOP_K=3
DATASET_SPLIT_SEED=13
EVIDENCE_SELECTION_BUDGET=3
EVIDENCE_FRONTIER_MULTIPLIER=4
EVIDENCE_QUERY_CONCEPT_WEIGHT=1.0
EVIDENCE_SUPPORT_WEIGHT=0.35
EVIDENCE_FAMILY_BONUS=0.20
EVIDENCE_REDUNDANCY_PENALTY=0.15
EVIDENCE_COST_PENALTY=0.05
BOOTSTRAP_SAMPLES=1000
REQUIRE_HELDOUT_EVAL=true
ALLOW_TRAIN_EVAL=false
POLICY_MIN_SUPERVISION_WEIGHT=0.45
POLICY_USE_FAILED_EPISODES=false

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j
